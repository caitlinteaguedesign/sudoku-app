{
  "name": "sudoku-app",
  "version": "2.0.0",
  "main": "server.js",
  "homepage": "https://github.com/caitlinteaguedesign/sudoku-app#readme",
  "scripts": {
    "start": "node server.js",
    "build": "cd client && npm install --include=dev && npm run build",
    "clean": "rmdir /s /q node_modules",
    "superclean": "npm run clean && cd client && npm run clean",
    "superinstall": "npm ci && cd client && npm ci",
    "dev-client": "npm start --prefix client",
    "dev": "concurrently -n server,client -c gray,cyan \"nodemon\" \"npm run dev-client\"",
    "serve-client": "npm run serve --prefix client",
    "serve": "concurrently -n server,client -c gray,cyan \"nodemon\" \"npm run serve-client\""
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "concurrently": "^6.5.1",
    "dotenv": "^17.3.1",
    "express": "^4.17.3",
    "is-empty": "^1.2.0",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "mongoose": "^6.2.8",
    "morgan": "^1.10.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "validator": "^13.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "engines": {
    "npm": "10.8.2",
    "node": "18.20.8"
  },
  "keywords": [],
  "description": "",
  "author": "",
  "license": "ISC",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caitlinteaguedesign/sudoku-app.git"
  }
}
