{
  "name": "sudoku-app",
  "version": "2.0.0",
  "main": "server.js",
  "homepage": "https://github.com/caitlinteaguedesign/sudoku-app#readme",
  "scripts": {
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install --include=dev",
    "buildout-client": "npm run install-client && npm run build",
    "server": "nodemon",
    "server-trace": "nodemon --trace-deprecation",
    "clean": "rmdir /s /q node_modules",
    "superclean": "npm run clean && cd client && npm run clean",
    "superinstall": "npm ci && cd client && npm ci",
    "client": "npm start --prefix client",
    "serve-client": "npm run serve --prefix client",
    "dev": "concurrently -n server,client -c gray,cyan \"npm run server\" \"npm run client\"",
    "serve": "concurrently -n server,client -c gray,cyan \"npm run server\" \"npm run serve-client\"",
    "export-puzzles": "mongoexport --uri=\"mongodb+srv://%npm_config_MONGO_ATLAS_USER%:%npm_config_MONGO_ATLAS_PW%@%npm_config_DATABASE_URL%\" --collection=puzzles --out=puzzles.json",
    "export-users": "mongoexport --uri=\"mongodb+srv://%npm_config_MONGO_ATLAS_USER%:%npm_config_MONGO_ATLAS_PW%@%npm_config_DATABASE_URL%\" --collection=users --out=users.json --pretty",
    "backup-db": "npm run export-puzzles && npm run export-users"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "concurrently": "^6.5.1",
    "express": "^4.17.3",
    "is-empty": "^1.2.0",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "mongoose": "^6.2.8",
    "morgan": "^1.10.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "validator": "^13.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "engines": {
    "npm": "10.8.2",
    "node": "18.20.8"
  },
  "keywords": [],
  "description": "",
  "author": "",
  "license": "ISC",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caitlinteaguedesign/sudoku-app.git"
  }
}
